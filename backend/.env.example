# SQLite is the default for local development.  Set this to a PostgreSQL URL in deployment.
DATABASE_URL=sqlite:///./wastewise.db
CORS_ORIGINS=http://localhost:5173
# Set a long, random value before deployment. Never commit the real value.
JWT_SECRET=change-this-before-deployment
# Optional path to the trained joblib model.  Without it, the prediction endpoint uses transparent rules.
MODEL_PATH=./artifacts/waste_risk_model.joblib
